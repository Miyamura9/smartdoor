DATABASE_URL="postgresql://postgres:password_kamu@localhost:5432/smart_door_lock"

# ─── MQTT Broker (HiveMQ Cloud) ───────────────────────────────────────────────
# Daftarkan akun gratis di: https://www.hivemq.com/mqtt-cloud-broker/
# Lalu buat sebuah cluster, dan copy Cluster URL, Username, Password ke bawah.
#
# Format URL: mqtts://<your-cluster-id>.s1.eu.hivemq.cloud
# Port MQTTS (TLS): 8883
#
MQTT_BROKER="mqtts://YOUR_CLUSTER_ID.s1.eu.hivemq.cloud"
MQTT_PORT=8883
MQTT_USERNAME="your_hivemq_username"
MQTT_PASSWORD="your_hivemq_password"

PORT=5000
FRONTEND_URL=http://localhost:3000
